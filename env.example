# Telegram API Configuration
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE_NUMBER=+1234567890
TELEGRAM_SESSION_NAME=grappa_session

# Application Configuration
GRAPPA_DEBUG=false
GRAPPA_LOG_LEVEL=INFO
GRAPPA_LOG_FILE=grappa.log
# Working directories; defaults live under ~/.grappa/data/
#GRAPPA_DATA_DIR=~/.grappa/data
#GRAPPA_DOWNLOADS_DIR=~/.grappa/data/downloads
#GRAPPA_SESSION_DIR=~/.grappa/data/sessions
GRAPPA_MAX_MESSAGES_PER_CHAT=1000
GRAPPA_CONTEXT_LENGTH=100
